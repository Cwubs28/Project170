    "import speech_recognition as sr\n",
    "\n",
    "recognize = sr.Recognizer()\n",
    "mic = sr.Microphone()\n",
    "\n",
    "with mic as source:\n",
    "    print(\"Say something\")\n",
    "    audio = recognize.listen(source)\n",
    "\n",
    "\n"
